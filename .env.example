# ── MongoDB (dedicated container — runs alongside the app) ───────────────────
# Username and password for the MongoDB container
# The connection URI is assembled automatically inside docker-compose.yml
MONGO_USER=adiyogi
MONGO_PASSWORD=replace_with_a_strong_mongo_password

# Strong random secret for JWT signing (generate with: openssl rand -hex 64)
JWT_SECRET=replace_with_a_strong_random_secret

# Your production domain (used for CORS — must match how users access the site)
CLIENT_URL=https://yourdomain.com

# Full URL of the backend (used in invoice links, etc.)
SERVER_URL=https://yourdomain.com

# Port nginx listens on inside the container (default 80, Coolify routes to it)
HTTP_PORT=80

# ── WhatsApp ─────────────────────────────────────────────────────────────────
# Admin WhatsApp number (country code + number, no + or spaces, e.g. 919876543210)
ADMIN_WHATSAPP=91XXXXXXXXXX

# Set to 'true' to enable automatic WhatsApp notifications on new orders
WHATSAPP_ENABLED=true

# ── ImageKit CDN ─────────────────────────────────────────────────────────────
IMAGEKIT_PUBLIC_KEY=your_public_key_here
IMAGEKIT_PRIVATE_KEY=your_private_key_here
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# ImageKit folder paths (defaults shown — override if needed)
IMAGEKIT_PRODUCT_IMAGES_FOLDER=adiyogi-internationals/product-images
IMAGEKIT_COLLECTION_IMAGES_FOLDER=adiyogi-internationals/collection-images
IMAGEKIT_INVOICES_FOLDER=adiyogi-internationals/invoices
